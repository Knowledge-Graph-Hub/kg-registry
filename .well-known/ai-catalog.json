      "capabilities": ["validate-schema", "check-provenance", "check-stub-cleanup"],
      "representativeQueries": [
        "validate this curated resource page",
        "check the provenance on this page"
      ],
      "version": "1.0.0",
      "updatedAt": "2026-06-19T00:00:00Z",
