    {
      "identifier": "urn:ai:kghub.org:kg-registry:kg-registry-validation",
      "displayName": "Validate a curated resource page",
      "type": "text/markdown",
      "url": "https://raw.githubusercontent.com/Knowledge-Graph-Hub/kg-registry/main/.agents/skills/kg-registry-validation/SKILL.md",
      "description": "Check a curated resource page for schema validity and curation-specific quality issues such as malformed provenance, missing products, or leftover stub content. Operates on a local clone.",
